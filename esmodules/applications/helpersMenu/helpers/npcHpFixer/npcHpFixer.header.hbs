			Actores
		</button>
		<button class="{{#if tabs.compendiums.active}}active{{/if}}" type="button" data-action="selectTab" data-tab="compendiums">
			<i class="fa-solid fa-book-atlas"></i>
			Compendios
		</button>
	</nav>
	{{/if}}
</div>