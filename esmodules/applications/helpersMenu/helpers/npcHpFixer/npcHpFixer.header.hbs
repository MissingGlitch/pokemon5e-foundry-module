<div class="header-part">
	{{#if views.actorsSelection.active}}
	<nav class="tabs-container">
		<button class="{{#if tabs.drop.active}}active{{/if}}" type="button" data-action="selectTab" data-tab="drop">
			<i class="fa-solid fa-hand"></i>
			Soltar
		</button>
		<button class="{{#if tabs.actors.active}}active{{/if}}" type="button" data-action="selectTab" data-tab="actors">
